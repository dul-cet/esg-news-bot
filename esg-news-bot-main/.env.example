# =============================================================================
# ESG News Bot — переменные окружения
# Скопируйте этот файл в .env и заполните обязательные поля.
# ВАЖНО: каждый экземпляр бота должен иметь уникальный TOKEN, KEY и DATABASE_PATH.
# =============================================================================

# -----------------------------------------------------------------------------
# ОБЯЗАТЕЛЬНЫЕ
# -----------------------------------------------------------------------------

# Токен Telegram-бота. Получить у @BotFather.
# Уникален для каждого экземпляра — нельзя использовать один токен на двух серверах.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# API-ключ Google Gemini. Получить на https://ai.google.dev
# Используется для AI-ответов на свободные вопросы пользователей.
GEMINI_API_KEY=your_gemini_api_key

# Путь к файлу базы данных SQLite.
# Должен быть уникальным — не должен совпадать с БД других сервисов на сервере.
DATABASE_PATH=./data/news.db

# -----------------------------------------------------------------------------
# ПРИЛОЖЕНИЕ
# -----------------------------------------------------------------------------

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Среда запуска: development | production
ENVIRONMENT=production

# Таймзона планировщика дайджестов (формат IANA)
TIMEZONE=Asia/Almaty

# Директория для файлов логов
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# GOOGLE GEMINI
# -----------------------------------------------------------------------------

# Модель Gemini. Варианты: gemini-2.0-flash | gemini-1.5-flash | gemini-2.0-flash-lite
GEMINI_MODEL_NAME=gemini-2.0-flash

# Температура генерации (0.0 = точно/сухо, 1.0 = творчески)
GEMINI_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# СЕТЬ И НАДЁЖНОСТЬ
# -----------------------------------------------------------------------------

# Таймаут одного HTTP-запроса к источникам новостей (секунды)
REQUEST_TIMEOUT_SEC=8

# Количество повторных попыток при ошибке сети
REQUEST_MAX_RETRIES=3

# Задержка между retry-попытками (секунды, умножается на номер попытки)
REQUEST_RETRY_BACKOFF_SEC=0.5

# SLA-цель: максимальное время ответа бота пользователю (секунды)
MAX_RESPONSE_TIME_SEC=2.0

# -----------------------------------------------------------------------------
# КЛАССИФИКАТОР
# -----------------------------------------------------------------------------

# Включить ESG-классификацию новостей
CLASSIFIER_ENABLED=true

# Минимальная уверенность для сохранения новости (0.0–1.0)
# Новости с уверенностью ниже этого порога отбрасываются.
CLASSIFIER_MIN_CONFIDENCE=0.3

# -----------------------------------------------------------------------------
# РАССЫЛКА
# -----------------------------------------------------------------------------

# Включить автоматические Push-дайджесты
PUSH_NOTIFICATIONS_ENABLED=true

# Час рассылки по умолчанию (0–23, по TIMEZONE выше)
PUSH_DIGEST_HOUR=9

# -----------------------------------------------------------------------------
# ОПЦИОНАЛЬНО
# -----------------------------------------------------------------------------

# Список Telegram user_id администраторов через запятую (если не указан — берётся из кода)
# Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=
